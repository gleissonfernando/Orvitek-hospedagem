PANEL_BOT_TOKEN=token_do_bot_do_painel
PANEL_CLIENT_ID=
PANEL_ADMIN_IDS=seu_discord_id,seu_outro_admin_id
ENABLE_MEMBER_EVENTS=false
HOSTED_BOTS_ENABLE_MEMBER_EVENTS=true
# Localmente use API_PORT. Em hospedagens como ShardCloud, a plataforma pode fornecer PORT automaticamente.
API_PORT=3000
API_PUBLIC_URL=https://sua-api-hospedagem.exemplo
HOSTING_BOT_API_URL=https://sua-api-hospedagem.exemplo
# Opcional. O sistema cadastra localmente em data/api-user-bots.json sem MongoDB.
MONGODB_URI=
MONGODB_DB_NAME=orvitek
MONGODB_HOSTING_EVENTS_COLLECTION=hosting_shutdown_events
MONGODB_HOSTING_PERMISSIONS_COLLECTION=hosting_registration_permissions
MONGODB_MIN_POOL_SIZE=5
MONGODB_MAX_POOL_SIZE=100
BOT_TOKEN_ENCRYPTION_KEY=gere_uma_chave_base64_de_32_bytes
ORVITEK_API_KEY=gere_uma_chave_secreta_para_o_bot_orvitek
ORVITEK_HOSTING_BOT_URL=https://sua-api-hospedagem.exemplo/api/orvitek/desligar
ORVITEK_HOSTING_BOT_TOKEN=gere_um_token_para_http_post_da_orvitek
ORVITEK_HOSTING_BOT_DEBUG=true
ORVITEK_MAIN_BOT_NOTIFY_URL=https://seu-bot-vendas.exemplo/hosting/bot-registered
ORVITEK_MAIN_BOT_NOTIFY_TOKEN=gere_um_token_para_notificar_o_bot_principal
CORS_ORIGIN=https://seu-painel-exemplo.invalid
ENABLE_DEV_MOCK_BOTS=false

# Opcional: coloque um GUILD_ID para registrar o comando instantaneamente em um servidor.
# Sem GUILD_ID, o comando sera global e pode demorar para aparecer.
GUILD_ID=

# Bots de teste. Configure estes valores diretamente na hospedagem/env,
# nunca pelo chat do Discord.
# Recomendado para varios usuarios:
TEST_BOT_1_OWNER_ID=id_de_discord_do_dono_1
TEST_BOT_1_SERVER_ID=id_do_servidor_1
TEST_BOT_1_CLIENT_ID=id_do_cliente_do_bot_1
TEST_BOT_1_TOKEN=token_do_bot_1

TEST_BOT_2_OWNER_ID=id_de_discord_do_dono_2
TEST_BOT_2_SERVER_ID=id_do_servidor_2
TEST_BOT_2_CLIENT_ID=id_do_cliente_do_bot_2
TEST_BOT_2_TOKEN=token_do_bot_2

# Opcional: tambem aceita JSON, mas o formato numerado acima e mais facil.
TEST_BOTS_JSON=

# Opcional: formato antigo para um bot so.
TEST_OWNER_ID=
TEST_BOT_CLIENT_ID=
TEST_BOT_TOKEN=
